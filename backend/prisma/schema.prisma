generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  active
  completed
  abandoned
}

enum Phase {
  plan
  build
  validate
  wrap
}

// Rubric variant for a question. v2.0 splits the plan rubric into two
// variants — `build` for buildable problems (60-min sessions) and
// `design` for production-scale design exercises. v1.0 questions stay
// on `mode = null` and route through the legacy single-rubric path.
enum Mode {
  build
  design
}

// Seniority calibration for an attempt. Same Question can be retried at
// different levels — that's why this lives on Session, not Question.
// Null on legacy rows; new v2.0+ Sessions default to `senior`.
enum Seniority {
  junior
  mid
  senior
  staff
}

model Question {
  id            String   @id @default(uuid()) @db.Uuid
  prompt        String
  rubricVersion String   @map("rubric_version")
  mode          Mode?
  createdAt     DateTime @default(now()) @map("created_at")

  sessions Session[]

  @@map("questions")
}

model Session {
  id              String        @id @default(uuid()) @db.Uuid
  questionId      String        @map("question_id") @db.Uuid
  projectPath     String?       @map("project_path")
  startedAt       DateTime      @default(now()) @map("started_at")
  endedAt         DateTime?     @map("ended_at")
  status          SessionStatus @default(active)
  seniority       Seniority?
  overallScore    Decimal?      @map("overall_score") @db.Decimal(3, 2)
  overallFeedback String?       @map("overall_feedback")

  // Build-phase fields (phase 2). buildTokenHash is bcrypt(secret)
  // where secret is the second half of the CLI's bearer token. Null
  // until the candidate clicks "Start build phase" on the web app.
  buildTokenHash   String?   @map("build_token_hash")
  buildStartedAt   DateTime? @map("build_started_at")
  buildEndedAt     DateTime? @map("build_ended_at")
  buildEventCount  Int       @default(0) @map("build_event_count")

  question Question @relation(fields: [questionId], references: [id], onDelete: Restrict)

  snapshots           Snapshot[]
  phaseEvaluations    PhaseEvaluation[]
  aiInteractions      AIInteraction[]
  finalArtifacts      FinalArtifacts?
  buildEvents         BuildEvent[]
  buildAiInteractions BuildAIInteraction[]

  @@index([questionId])
  @@map("sessions")
}

// One row per file save captured by the CLI watcher during the build
// phase. Either `content` (first capture) or `contentDiff` (unified
// patch) is populated — never both, never neither (except deletes,
// which carry no payload).
model BuildEvent {
  id           String   @id @default(uuid()) @db.Uuid
  sessionId    String   @map("session_id") @db.Uuid
  filePath     String   @map("file_path")
  action       String
  content      String?
  contentDiff  String?  @map("content_diff")
  occurredAt   DateTime @map("occurred_at")
  receivedAt   DateTime @default(now()) @map("received_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, occurredAt])
  @@map("build_events")
}

// One row per turn captured from a Claude Code conversation log
// (~/.claude/projects/<encodedCwd>/*.jsonl) during the build phase.
// Truncated at the CLI before shipping (text ≤ 4 KB, tool result ≤ 1 KB).
// Unique constraint on (sessionId, externalSessionId, turnIndex) so
// re-shipped turns from a wiped CLI cursor file silently dedupe via
// createMany({ skipDuplicates: true }).
model BuildAIInteraction {
  id                  String   @id @default(uuid()) @db.Uuid
  sessionId           String   @map("session_id") @db.Uuid
  tool                String
  externalSessionId   String   @map("external_session_id")
  turnIndex           Int      @map("turn_index")
  role                String
  text                String?
  toolName            String?  @map("tool_name")
  toolInputSummary    String?  @map("tool_input_summary")
  toolResultSummary   String?  @map("tool_result_summary")
  occurredAt          DateTime @map("occurred_at")
  receivedAt          DateTime @default(now()) @map("received_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, externalSessionId, turnIndex], name: "uniq_session_turn")
  @@index([sessionId, occurredAt])
  @@map("build_ai_interactions")
}

model Snapshot {
  id              String   @id @default(uuid()) @db.Uuid
  sessionId       String   @map("session_id") @db.Uuid
  takenAt         DateTime @default(now()) @map("taken_at")
  elapsedMinutes  Int      @map("elapsed_minutes")
  inferredPhase   String?  @map("inferred_phase")
  artifacts       Json
  judgeNote       Json?    @map("judge_note")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("snapshots")
}

model PhaseEvaluation {
  id                  String   @id @default(uuid()) @db.Uuid
  sessionId           String   @map("session_id") @db.Uuid
  phase               Phase
  score               Decimal  @db.Decimal(3, 2)
  signalResults       Json     @map("signal_results")
  feedbackText        String   @map("feedback_text")
  topActionableItems  Json     @map("top_actionable_items")
  // Topics directly relevant to the question that the candidate either
  // missed or only lightly touched — input to the future study feature
  // that aggregates gaps across sessions. Empty array on legacy rows.
  gapTopics           Json     @default("[]") @map("gap_topics")
  evaluatedAt         DateTime @default(now()) @map("evaluated_at")

  session  Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  audit         EvaluationAudit?
  mentor        MentorArtifact?
  signalMentor  SignalMentorArtifact?

  // Each Re-evaluate inserts a new row (no upsert); history is preserved.
  // Ordered index makes "latest plan eval for session X" a single seek.
  @@index([sessionId, phase, evaluatedAt(sort: Desc)])
  @@index([signalResults], type: Gin)
  @@map("phase_evaluations")
}

// 1:1 audit row per PhaseEvaluation. Captures the exact prompt sent to the
// LLM and the raw response text — not duplicated metadata, but the bytes
// the parser ate. Useful for debugging hallucinations, parse failures, and
// diffing how prompt edits shift judgments over time.
model EvaluationAudit {
  id                  String   @id @default(uuid()) @db.Uuid
  phaseEvaluationId   String   @unique @map("phase_evaluation_id") @db.Uuid
  prompt              String
  rawResponse         String   @map("raw_response")
  modelUsed           String   @map("model_used")
  tokensIn            Int      @map("tokens_in")
  tokensOut           Int      @map("tokens_out")
  cacheReadTokens     Int      @default(0) @map("cache_read_tokens")
  cacheCreationTokens Int      @default(0) @map("cache_creation_tokens")
  latencyMs           Int?     @map("latency_ms")
  createdAt           DateTime @default(now()) @map("created_at")

  phaseEvaluation PhaseEvaluation @relation(fields: [phaseEvaluationId], references: [id], onDelete: Cascade)

  @@map("evaluation_audits")
}

// Mentor-voice artifact, 1:1 with a phase_evaluation. Generated on user
// request from a separate LLM call; not part of the eval HTTP path.
// Calling generate again upserts (overwrites) so re-runs aren't an append.
model MentorArtifact {
  id                  String   @id @default(uuid()) @db.Uuid
  phaseEvaluationId   String   @unique @map("phase_evaluation_id") @db.Uuid
  content             String
  modelUsed           String   @map("model_used")
  tokensIn            Int      @map("tokens_in")
  tokensOut           Int      @map("tokens_out")
  cacheReadTokens     Int      @default(0) @map("cache_read_tokens")
  cacheCreationTokens Int      @default(0) @map("cache_creation_tokens")
  latencyMs           Int?     @map("latency_ms")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  phaseEvaluation PhaseEvaluation @relation(fields: [phaseEvaluationId], references: [id], onDelete: Cascade)

  @@map("mentor_artifacts")
}

// Per-signal coaching artifact, 1:1 with a phase_evaluation. Generated
// in the background after evaluation persists; populated only for "gap"
// signals (missed-good and fired-bad). Stored as a JSON map of
// {signal_id → annotation_text}.
model SignalMentorArtifact {
  id                  String   @id @default(uuid()) @db.Uuid
  phaseEvaluationId   String   @unique @map("phase_evaluation_id") @db.Uuid
  annotations         Json
  modelUsed           String   @map("model_used")
  tokensIn            Int      @map("tokens_in")
  tokensOut           Int      @map("tokens_out")
  cacheReadTokens     Int      @default(0) @map("cache_read_tokens")
  cacheCreationTokens Int      @default(0) @map("cache_creation_tokens")
  latencyMs           Int?     @map("latency_ms")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  phaseEvaluation PhaseEvaluation @relation(fields: [phaseEvaluationId], references: [id], onDelete: Cascade)

  @@map("signal_mentor_artifacts")
}

model AIInteraction {
  id                      String   @id @default(uuid()) @db.Uuid
  sessionId               String   @map("session_id") @db.Uuid
  occurredAt              DateTime @map("occurred_at")
  elapsedMinutes          Int      @map("elapsed_minutes")
  inferredPhase           String?  @map("inferred_phase")
  prompt                  String
  response                String
  modelUsed               String   @map("model_used")
  tokensIn                Int      @map("tokens_in")
  tokensOut               Int      @map("tokens_out")
  artifactStateAtPrompt   Json     @map("artifact_state_at_prompt")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([inferredPhase])
  @@map("ai_interactions")
}

model FinalArtifacts {
  sessionId     String  @id @map("session_id") @db.Uuid
  planMd        String? @map("plan_md")
  gitLog        String? @map("git_log")
  aiPromptsLog  String? @map("ai_prompts_log")
  reflection    String?
  codeFiles     Json    @map("code_files")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("final_artifacts")
}
