# ---------------------------------------------------------------------------
# Root .gitignore
#
# Truly repo-wide rules only. Per-area generated artifacts are handled
# closer to where they're produced:
#   - agents/.gitignore         everything generated under agents/data/
#                                and dist/node_modules for agents/packages/*
#   - backend/.gitignore        node_modules + dist + prisma + graphify-out
#   - frontend/.gitignore       node_modules + dist
#   - cli/.gitignore            node_modules + dist
# ---------------------------------------------------------------------------

# OS / editor noise
.DS_Store
*.swp
.vscode/
.idea/

# Local working planning docs — edit freely, not for version control.
production-hardening.md
gaps.md
